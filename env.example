# Ilograph MCP Server Configuration

# Server Settings
MCP_HOST=localhost
MCP_PORT=8000

# Ilograph API Settings
ILOGRAPH_API_KEY=your_ilograph_api_key_here
ILOGRAPH_API_BASE_URL=https://export.ilograph.com

# Analysis Settings
MAX_FILE_SIZE_MB=10
MAX_ANALYSIS_TIME_SECONDS=120

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Performance Settings
ENABLE_CACHING=true
CACHE_TTL_SECONDS=3600

# Security Settings
REQUIRE_API_KEY=false
ALLOWED_HOSTS=*

# Output Settings
DEFAULT_OUTPUT_DIR=./output
MAX_OUTPUT_FILE_SIZE_MB=100

# Development Settings (optional)
DEBUG=false
RELOAD=false 